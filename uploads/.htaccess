# Sécurité pour le dossier uploads
# Empêcher l'exécution de scripts PHP dans ce dossier

# Désactiver l'exécution de PHP
php_flag engine off

# Autoriser uniquement les images
<FilesMatch "\.(jpg|jpeg|png|gif|webp)$">
    Order Allow,Deny
    Allow from all
</FilesMatch>

# Bloquer tous les autres types de fichiers
<FilesMatch "\.">
    Order Deny,Allow
    Deny from all
</FilesMatch>

# Autoriser les images
<FilesMatch "\.(jpg|jpeg|png|gif|webp)$">
    Order Allow,Deny
    Allow from all
</FilesMatch>
