{
  "$schema": "https://json.schemastore.org/prettierrc",
  "printWidth": 100,
  "semi": true,
  "singleQuote": false,
  "trailingComma": "all",
  "bracketSpacing": true,
  "endOfLine": "lf",
  "overrides": [
    {
      "files": ["*.css", "*.js", "*.json", "*.md"],
      "options": {
        "tabWidth": 4
      }
    }
  ]
}
