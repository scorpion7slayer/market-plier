# ============================================================
# Market Plier — Variables d'environnement
# Copier ce fichier en .env et remplir les valeurs
# Ne jamais commiter .env dans le dépôt
# ============================================================

# ------------------------------------------------------------
# Base de données MySQL
# ------------------------------------------------------------
DB_HOST=localhost
DB_NAME=marketplier
DB_USER=root
DB_PASS=

# ------------------------------------------------------------
# URL de base de l'application
# Exemples :
#   http://localhost/market-plier
#   https://market-plier.ddev.site (si DDEV est utilisé)
# ------------------------------------------------------------
APP_URL=http://localhost/market-plier

# ------------------------------------------------------------
# Stripe
# Clés disponibles sur https://dashboard.stripe.com/apikeys
# Utiliser les clés sk_test_ / pk_test_ en développement
# ------------------------------------------------------------
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLIC_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# ------------------------------------------------------------
# Google OAuth 2.0
# Créer un projet sur https://console.cloud.google.com
# Activer l'API Google+ et créer des identifiants OAuth 2.0
# ------------------------------------------------------------
GOOGLE_CLIENT_ID=...apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-...
GOOGLE_REDIRECT_URI=http://localhost/market-plier/google/google_callback.php

# ------------------------------------------------------------
# Web Push (VAPID)
# Générer les clés avec : vendor/bin/web-push generate-vapid-keys
# ou en PHP : Minishlink\WebPush\VAPID::createVapidKeys()
# ------------------------------------------------------------
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:contact@example.com
